<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>AutoUpdater</AssemblyName>
    <RootNamespace>FortyOne.AudioSwitcher.AutoUpdater</RootNamespace>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <PlatformTarget>x86</PlatformTarget>
  </PropertyGroup>

  <!-- Exclude the old auto-generated SOAP proxy files that are no longer needed -->
  <ItemGroup>
    <None Include="Web References\AudioSwitcherService\AudioSwitcher.disco" />
    <None Include="Web References\AudioSwitcherService\AudioSwitcher.wsdl" />
    <None Include="Web References\AudioSwitcherService\AudioSwitcherVersionInfo.datasource" />
    <None Include="Web References\AudioSwitcherService\Reference.map" />
    <Compile Remove="Web References\AudioSwitcherService\Reference.cs" />
  </ItemGroup>

</Project>

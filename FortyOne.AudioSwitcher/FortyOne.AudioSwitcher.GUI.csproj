<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>AudioSwitcher</AssemblyName>
    <RootNamespace>FortyOne.AudioSwitcher</RootNamespace>
    <ApplicationIcon>Resources\Music_Note_Double.ico</ApplicationIcon>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <PlatformTarget>x86</PlatformTarget>
    <Optimize Condition="'$(Configuration)' == 'Release'">true</Optimize>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AudioSwitcher.AudioApi" Version="4.0.0-alpha5" />
    <PackageReference Include="AudioSwitcher.AudioApi.CoreAudio" Version="4.0.0-alpha5" />
    <PackageReference Include="fastJSON" Version="2.1.21" />
    <PackageReference Include="WindowsInput" Version="0.2.0.0" />
  </ItemGroup>


</Project>
